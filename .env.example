DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=

# Docker Compose / PostgreSQL
POSTGRES_USER=serverlegends
POSTGRES_PASSWORD=changeme
POSTGRES_DB=serverlegends

# Lokalne uruchomienie (bez Dockera)
DATABASE_URL=postgresql://serverlegends:changeme@localhost:5432/serverlegends

# Produkcja / Kubernetes
# DATABASE_URL=postgresql://serverlegends:twoje_haslo@postgres.postgres.svc.cluster.local:5432/serverlegends

# Deploy na wlasny serwer przez SSH
# DEPLOY_HOST=user@your-server
# DEPLOY_REMOTE_DIR=/home/ubuntu/serverlegends-deploy
# DEPLOY_DATABASE_URL=postgresql://serverlegends:twoje_haslo@postgres.postgres.svc.cluster.local:5432/serverlegends
# K8S_NAMESPACE=serverlegends
# K8S_SECRET_NAME=serverlegends-secret
# K8S_DEPLOYMENT_NAME=serverlegends-bot
# K8S_APP_LABEL=serverlegends-bot
# DOCKER_IMAGE=serverlegends-bot:latest

# Domyslnie skrypt zaklada Docker + kubectl + K3s na zdalnym serwerze.
# Zmien ponizsze, jesli uzywasz innych komend albo klastra bez K3s.
# DEPLOY_KUBECTL_CMD=sudo kubectl
# DEPLOY_DOCKER_CMD=sudo docker
# DEPLOY_IMAGE_IMPORT_CMD=sudo k3s ctr images import
# DEPLOY_SKIP_IMAGE_IMPORT=false

# Tryb developerski
NODE_ENV=development
DEV_USER_IDS=
